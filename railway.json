{
  "$schema": "https://railway.app/railway-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "/bin/sh -c \"uvicorn src.api.main:app --host 0.0.0.0 --port $PORT\"",
    "healthcheckPath": "/health"
  },
  "restartPolicy": {
    "type": "on_failure",
    "maxRetries": 3
  }
}
