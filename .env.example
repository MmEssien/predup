# Database
DATABASE_URL=postgresql://user:password@localhost:5432/predup

# API-Football
API_FOOTBALL_API_KEY=your_api_key_here
API_FOOTBALL_BASE_URL=https://api.football-data-org/v4

# App Config
APP_ENV=development
LOG_LEVEL=INFO
API_RATE_LIMIT=10

# Model Settings
MIN_CONFIDENCE_THRESHOLD=0.75
ENSEMBLE_WEIGHT_XGB=0.4
ENSEMBLE_WEIGHT_LGBM=0.4
ENSEMBLE_WEIGHT_LOGREG=0.2