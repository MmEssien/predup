{
  "version": 2,
  "functions": {
    "src/api/main.py": {
      "maxDuration": 30,
      "memory": 1024,
      "excludeFiles": ["scripts/**", "tests/**", "__pycache__/**", "*.pyc", ".cache/**", "docs/**", "test_*.py", "debug_*.py", "check_*.py"]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/api/main.py"
    }
  ]
}